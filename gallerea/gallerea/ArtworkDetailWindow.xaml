<Window x:Class="gallarea.ArtworkDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детальный просмотр" 
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        PreviewMouseWheel="Window_PreviewMouseWheel">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <!-- Изображение и информация -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Image x:Name="ArtImage" Stretch="None"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                        <TextBlock Text="Масштаб:" VerticalAlignment="Center"/>
                        <Slider x:Name="ZoomSlider" Width="150" Minimum="0.5" Maximum="3" Value="1" Margin="5,0"/>
                        <TextBlock x:Name="ZoomText" Text="1.0x" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <TextBlock Text="ИНФОРМАЦИЯ" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <TextBlock Text="Название:" FontWeight="Bold"/>
                <TextBlock x:Name="TitleText" Margin="0,0,0,5" TextWrapping="Wrap"/>

                <TextBlock Text="Автор:" FontWeight="Bold"/>
                <TextBlock x:Name="AuthorText" Margin="0,0,0,5"/>

                <TextBlock Text="Год:" FontWeight="Bold"/>
                <TextBlock x:Name="YearText" Margin="0,0,0,5"/>

                <TextBlock Text="Техника:" FontWeight="Bold"/>
                <TextBlock x:Name="TechniqueText" Margin="0,0,0,5"/>

                <TextBlock Text="Жанр:" FontWeight="Bold"/>
                <TextBlock x:Name="GenreText" Margin="0,0,0,5"/>

                <TextBlock Text="Стиль:" FontWeight="Bold"/>
                <TextBlock x:Name="StyleText" Margin="0,0,0,5"/>

                <TextBlock Text="Описание:" FontWeight="Bold"/>
                <TextBox x:Name="DescText" TextWrapping="Wrap" Height="80" IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,5"/>
            </StackPanel>
        </Grid>

        <!-- Разделитель -->
        <Border Grid.Row="1" Height="1" Background="Gray" Margin="0,10"/>

        <!-- Комментарии -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="КОММЕНТАРИИ" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

            <ListBox x:Name="CommentsList" Grid.Row="1" Margin="0,5,0,5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5" Margin="0,0,0,3">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding UserName}" FontWeight="Bold"/>
                                    <TextBlock Text=" оценил(а): " Margin="5,0"/>
                                    <TextBlock Text="{Binding Rating}" FontWeight="Bold"/>
                                    <TextBlock Text="/5" Margin="2,0"/>
                                    <TextBlock Text="{Binding Date, StringFormat='dd.MM.yyyy HH:mm'}" 
                                               Margin="10,0,0,0" FontStyle="Italic" FontSize="10"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="10,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Добавление комментария -->
            <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Имя:" VerticalAlignment="Center"/>
                    <TextBox x:Name="UserNameBox" Grid.Row="0" Grid.Column="1" Margin="2" Height="22"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Оценка:" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="2">
                        <RadioButton x:Name="Rate1" Content="1" GroupName="Rate" Margin="2" VerticalAlignment="Center"/>
                        <RadioButton x:Name="Rate2" Content="2" GroupName="Rate" Margin="2" VerticalAlignment="Center"/>
                        <RadioButton x:Name="Rate3" Content="3" GroupName="Rate" Margin="2" VerticalAlignment="Center"/>
                        <RadioButton x:Name="Rate4" Content="4" GroupName="Rate" Margin="2" VerticalAlignment="Center"/>
                        <RadioButton x:Name="Rate5" Content="5" GroupName="Rate" IsChecked="True" Margin="2" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Коммент:" VerticalAlignment="Top"/>
                    <TextBox x:Name="CommentBox" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Height="50" Margin="2"/>

                    <Button x:Name="AddCommentBtn" Content="Добавить" Grid.Row="2" Grid.Column="2" 
                            Width="70" Height="50" Margin="2" Click="AddCommentBtn_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>