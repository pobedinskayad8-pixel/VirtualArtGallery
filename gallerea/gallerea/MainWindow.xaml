<Window x:Class="gallarea.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Виртуальная арт-галерея" 
    Height="550" 
    Width="900"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Фильтры -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Жанр:" VerticalAlignment="Center"/>
            <ComboBox x:Name="GenreFilter" Width="120" Margin="5" SelectionChanged="Filter_Changed"/>
            <Label Content="Стиль:" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <ComboBox x:Name="StyleFilter" Width="120" Margin="5" SelectionChanged="Filter_Changed"/>
            <Button Content="Сброс" Width="80" Margin="20,5,5,5" Click="ResetFilter_Click"/>
        </StackPanel>

        <!-- Список и предпросмотр -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Список произведений -->
            <ListBox x:Name="ArtworksList" Grid.Column="0" 
                     DisplayMemberPath="Title"
                     SelectionChanged="ArtworksList_SelectionChanged"
                     Margin="0,0,10,0"/>

            <!-- Предпросмотр -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="Предпросмотр" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Image x:Name="PreviewImg" Height="150" Stretch="Uniform" Margin="0,0,0,10"/>
                    <TextBlock x:Name="PreviewTitle" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="PreviewAuthor" FontSize="14"/>
                    <TextBlock x:Name="PreviewYear" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ViewBtn" Content="Детально" Width="100" Height="30" Margin="5" Click="ViewBtn_Click"/>
            <Button x:Name="AddBtn" Content="Добавить" Width="100" Height="30" Margin="5" Click="AddBtn_Click"/>
            <Button x:Name="ExhibitionsBtn" Content="Выставки" Width="100" Height="30" Margin="5" Click="ExhibitionsBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
