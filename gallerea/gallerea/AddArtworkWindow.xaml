<Window x:Class="gallarea.AddArtworkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить произведение" 
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="НОВОЕ ПРОИЗВЕДЕНИЕ" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:*" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="TitleBox" Grid.Row="0" Grid.Column="1" Margin="2" Height="25"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Автор:*" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="AuthorBox" Grid.Row="1" Grid.Column="1" Margin="2" Height="25"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Год:" VerticalAlignment="Center"/>
                <TextBox x:Name="YearBox" Grid.Row="2" Grid.Column="1" Margin="2" Height="25"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Техника:" VerticalAlignment="Center"/>
                <TextBox x:Name="TechBox" Grid.Row="3" Grid.Column="1" Margin="2" Height="25"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Жанр:" VerticalAlignment="Center"/>
                <TextBox x:Name="GenreBox" Grid.Row="4" Grid.Column="1" Margin="2" Height="25"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Стиль:" VerticalAlignment="Center"/>
                <TextBox x:Name="StyleBox" Grid.Row="5" Grid.Column="1" Margin="2" Height="25"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Описание:" VerticalAlignment="Top"/>
                <TextBox x:Name="DescBox" Grid.Row="6" Grid.Column="1" TextWrapping="Wrap" Height="80" Margin="2"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Изображение:*" VerticalAlignment="Center" FontWeight="Bold"/>
                <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
                    <TextBox x:Name="ImagePathBox" Width="350" Height="25" IsReadOnly="True"/>
                    <Button x:Name="BrowseBtn" Content="Обзор..." Width="70" Height="25" Margin="5,0,0,0" Click="BrowseBtn_Click"/>
                </StackPanel>

                <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" 
                        BorderBrush="Gray" BorderThickness="1" Margin="2" Padding="5" Height="150">
                    <Image x:Name="PreviewImage" Height="140" Stretch="Uniform" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="80" Height="30" Margin="5" Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="80" Height="30" Margin="5" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>